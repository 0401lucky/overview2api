PORT=3000
API_KEY=change-me
ADMIN_KEY=change-me
ACCOUNTS_FILE=./data/accounts.json

CLICKUP_WORKSPACE_ID=90141378436
# 可选。默认留空，每次请求自动新建 ClickUp AI 会话，避免上下文串台。
CLICKUP_CONVERSATION_ID=
CLICKUP_REUSE_CONVERSATION=false

# 推荐 Zeabur 使用这个，让服务自动换发短期 JWT 和 frontdoor accessToken。
# 从浏览器 DevTools 的 refresh_token/access_tokens 请求里手动复制 Cookie 请求头。
CLICKUP_AUTH_COOKIE=

# 备选：只填短期 workspace JWT。通常约 48 小时过期，过期后需要手动更新。
CLICKUP_JWT=

# 多账号也可以用 JSON 环境变量启动；更推荐部署后打开 /admin 管理。
# CLICKUP_ACCOUNTS_JSON=[{"id":"a1","name":"账号1","workspaceId":"90141378436","conversationId":"","authCookie":"..."}]

CLICKUP_DEFAULT_MODEL=Brain² Max
CLICKUP_TIMEOUT_MS=120000
CLICKUP_REQUEST_TIMEOUT_MS=30000
CLICKUP_TOKEN_REFRESH_SKEW_SECONDS=60
CLICKUP_ACCOUNT_COOLDOWN_MS=900000
# 每个账号的预估额度提醒阈值。默认 50；填 0 表示不提醒，不会强制停用。
CLICKUP_ACCOUNT_QUOTA_LIMIT=50

MODEL_OWNER=clickup
